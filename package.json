    "@angular/router": "^21.2.0",
    "@fontsource-variable/noto-sans-arabic": "^5.2.10",
    "@fontsource/geist": "^5.2.8",
    "@jsverse/transloco": "8.3.0",
    "@ng-icons/core": ">=32.0.0 <34.0.0",
    "@ng-icons/lucide": ">=32.0.0 <34.0.0",
